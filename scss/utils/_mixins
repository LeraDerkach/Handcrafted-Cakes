@mixin flex {
    display: flex;
    justify-content: center;
}


@mixin background {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}

@mixin span {
    font-family: "Lavishly Yours", cursive;
    font-weight: 400;
    font-style: normal;
    font-size: 36px;
}

@mixin hover {
    box-shadow: 0px 0px 15px 15px #e69090;
    transform: scale(1.2);
}
